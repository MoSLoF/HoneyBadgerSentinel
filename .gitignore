# HoneyBadger Sentinel - Git Ignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.env
.venv
env/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Database files (don't commit production data)
*.db
*.sqlite
*.sqlite3

# Logs
*.log
logs/

# Environment/secrets (NEVER commit these)
*.env.local
*.env.production
secrets/
.secrets
api_keys.txt

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
tmp/
temp/

# Queue directories
*-queue/
