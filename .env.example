# HoneyBadger Sentinel - Environment Configuration Example
# Copy this file to .env or set these as environment variables
# For systemd services, edit /etc/hbv-sentinel/collector.env or /etc/hbv-sentinel/agent.env

# ═══════════════════════════════════════════════════════════════════════
# COLLECTOR CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════

# Server Settings
HBV_HOST=0.0.0.0
HBV_PORT=8443

# Database
HBV_DB_PATH=/opt/hbv-sentinel/sentinel.db
HBV_RETENTION_DAYS=30

# Authentication
# Set to 'true' to require API key for beacon submissions
HBV_API_KEY_REQUIRED=false
# Generate with: python3 sentinel-collector.py --generate-key
HBV_API_KEY=your-secure-api-key-here

# CORS (comma-separated list of allowed origins, or * for all)
HBV_ALLOWED_ORIGINS=*

# Rate Limiting
# Max requests per client per window
HBV_RATE_LIMIT_REQUESTS=100
# Window in seconds
HBV_RATE_LIMIT_WINDOW=60

# Alert Thresholds (percentage/degrees)
HBV_ALERT_CPU=90
HBV_ALERT_MEMORY=90
HBV_ALERT_DISK=90
HBV_ALERT_GPU_TEMP=85

# Logging (DEBUG, INFO, WARNING, ERROR)
HBV_LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════════════
# AGENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════

# Agent Identity (defaults to hostname)
# HBV_AGENT_ID=my-server-01

# Collector URL
HBV_COLLECTOR_URL=http://192.168.36.241:8443/api/beacon

# API Key (must match collector if HBV_API_KEY_REQUIRED=true)
# HBV_API_KEY=your-secure-api-key-here

# Beacon Settings
HBV_BEACON_INTERVAL=30
HBV_MAX_RETRIES=3
HBV_RETRY_DELAY=5
HBV_REQUEST_TIMEOUT=10

# Queue Settings
HBV_QUEUE_PATH=/tmp/hbv-sentinel-queue
HBV_MAX_QUEUE_SIZE=100

# Metrics Collection (true/false)
HBV_COLLECT_CPU=true
HBV_COLLECT_MEMORY=true
HBV_COLLECT_DISK=true
HBV_COLLECT_NETWORK=true
HBV_COLLECT_TEMPERATURE=true
HBV_COLLECT_RAID=true
HBV_COLLECT_SERVICES=true
HBV_COLLECT_GPU=true

# Logging
HBV_LOG_PATH=/var/log/hbv-sentinel.log
# HBV_LOG_LEVEL=INFO
